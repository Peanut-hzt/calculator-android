<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.ScientificCalculator" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <item name="colorPrimary">#667eea</item>
        <item name="colorPrimaryVariant">#764ba2</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">#03DAC5</item>
        <item name="colorSecondaryVariant">#018786</item>
        <item name="colorOnSecondary">@color/black</item>
    </style>

    <style name="NumberButton">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">60dp</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_margin">4dp</item>
        <item name="android:textSize">24sp</item>
        <item name="android:backgroundTint">#f7f9fc</item>
        <item name="android:textColor">#333333</item>
    </style>

    <style name="OperatorButton">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">60dp</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_margin">4dp</item>
        <item name="android:textSize">24sp</item>
        <item name="android:backgroundTint">#667eea</item>
        <item name="android:textColor">#FFFFFF</item>
    </style>

    <style name="FunctionButton">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">50dp</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_margin">2dp</item>
        <item name="android:textSize">14sp</item>
        <item name="android:backgroundTint">#4ecdc4</item>
        <item name="android:textColor">#FFFFFF</item>
    </style>

    <style name="ClearButton">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">60dp</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_margin">4dp</item>
        <item name="android:textSize">24sp</item>
        <item name="android:backgroundTint">#ff6b6b</item>
        <item name="android:textColor">#FFFFFF</item>
    </style>

    <style name="DeleteButton">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">60dp</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_margin">4dp</item>
        <item name="android:textSize">24sp</item>
        <item name="android:backgroundTint">#4ecdc4</item>
        <item name="android:textColor">#FFFFFF</item>
    </style>

    <style name="EqualButton">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">60dp</item>
        <item name="android:layout_weight">2</item>
        <item name="android:layout_margin">4dp</item>
        <item name="android:textSize">24sp</item>
        <item name="android:backgroundTint">#764ba2</item>
        <item name="android:textColor">#FFFFFF</item>
    </style>
</resources>
